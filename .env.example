APP_NAME=SmartCopilot
APP_ENV=local
API_V1_PREFIX=/api/v1
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8081

MYSQL_DSN=mysql+asyncmy://root:password@localhost:3306/smartcopilot
REDIS_URL=redis://localhost:6379/0
ELASTICSEARCH_URL=http://localhost:9200
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false
MINIO_UPLOAD_BUCKET=uploads
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_FILE_PROCESSING_TOPIC=file-processing
KAFKA_FILE_PROCESSING_GROUP_ID=smartcopilot-file-processing
UPLOAD_STORAGE_DIR=storage/uploads

LLM_REQUEST_TIMEOUT_SECONDS=60

# Free chat model used when chat modelMode=FREE.
FREE_LLM_BASE_URL=https://api.deepseek.com
FREE_LLM_API_KEY=xxx
FREE_LLM_MODEL=deepseek-chat

# Paid chat model used when chat modelMode=PAID.
PAID_LLM_BASE_URL=https://api.deepseek.com
PAID_LLM_API_KEY=xxx
PAID_LLM_MODEL=deepseek-chat

SHORT_TERM_MEMORY_TURNS=8
LONG_TERM_MEMORY_ENABLED=true
LONG_TERM_MEMORY_TOP_K=5
LONG_TERM_MEMORY_EXTRACT_EVERY_TURNS=5
LONG_TERM_MEMORY_EXTRACT_WINDOW_TURNS=10
LONG_TERM_MEMORY_INDEX_NAME=user_memories

EMBEDDING_PROVIDER=openai-compatible
EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_API_KEY=xxx
EMBEDDING_MODEL=text-embedding-v4
EMBEDDING_DIMENSION=1024
EMBEDDING_REQUEST_TIMEOUT_SECONDS=60
RAG_CHUNK_SIZE=1200
RAG_CHUNK_OVERLAP=150
ELASTICSEARCH_INDEX_NAME=document_vectors

JWT_SECRET=change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_SECONDS=3600
REFRESH_TOKEN_EXPIRE_SECONDS=604800
